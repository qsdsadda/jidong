# 即动 环境变量配置示例
# 复制此文件为 .env，填入真实密钥后本地运行

# DeepSeek API 密钥（在 https://platform.deepseek.com 申请）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# Flask Session 密钥（随机字符串，可用 python -c "import secrets; print(secrets.token_hex(32)" 生成）
SECRET_KEY=change_this_to_a_random_string

# 数据库路径（默认 SQLite，无需修改）
DATABASE_URL=sqlite:///jidong.db

# 本地调试模式（生产环境设置为 0）
FLASK_DEBUG=0
